# ── App ────────────────────────────────────────────────────────────
APP_NAME=Realty DOE Agent
APP_ENV=development
DEBUG=true
LOG_LEVEL=INFO

# ── Meta WhatsApp Cloud API ───────────────────────────────────────
WHATSAPP_API_URL=https://graph.facebook.com/v19.0
WHATSAPP_ACCESS_TOKEN=your-whatsapp-access-token
WHATSAPP_PHONE_NUMBER_ID=your-phone-number-id
WHATSAPP_BUSINESS_ACCOUNT_ID=your-business-account-id
WHATSAPP_VERIFY_TOKEN=your-webhook-verify-token
WHATSAPP_APP_SECRET=your-app-secret

# ── LLM Providers (set LLM_PROVIDER to choose) ───────────────────
LLM_PROVIDER=openai

OPENAI_API_KEY=sk-...
OPENAI_MODEL=gpt-4o
OPENAI_TEMPERATURE=0.3

GOOGLE_API_KEY=your-google-api-key
GOOGLE_MODEL=gemini-2.0-flash

ANTHROPIC_API_KEY=sk-ant-...
ANTHROPIC_MODEL=claude-sonnet-4-20250514

# ── PostgreSQL ────────────────────────────────────────────────────
DATABASE_URL=postgresql+asyncpg://realty:realty@postgres:5432/realty_db
DB_POOL_SIZE=20
DB_MAX_OVERFLOW=10

# ── Redis ─────────────────────────────────────────────────────────
REDIS_URL=redis://redis:6379/0
REDIS_SESSION_TTL=86400

# ── Google Calendar ───────────────────────────────────────────────
GOOGLE_CALENDAR_ID=primary
GOOGLE_SERVICE_ACCOUNT_JSON=/path/to/service-account.json
CALENDAR_SLOT_DURATION_MIN=30
CALENDAR_TZ=America/New_York

# ── Mapbox ────────────────────────────────────────────────────────
MAPBOX_ACCESS_TOKEN=pk.your-mapbox-token
MAPBOX_STYLE=mapbox://styles/mapbox/streets-v12

# ── JWT / Auth ────────────────────────────────────────────────────
JWT_SECRET_KEY=change-me-to-a-random-secret
JWT_ALGORITHM=HS256
JWT_ACCESS_TOKEN_EXPIRE_MINUTES=30
JWT_REFRESH_TOKEN_EXPIRE_DAYS=7

# ── CORS ──────────────────────────────────────────────────────────
CORS_ORIGINS=["http://localhost:3000"]

# ── Rate Limiting ─────────────────────────────────────────────────
RATE_LIMIT_REQUESTS=60
RATE_LIMIT_WINDOW_SECONDS=60

# ── Nurture Engine ────────────────────────────────────────────────
NURTURE_REENGAGE_HOURS=48
NURTURE_MAX_FOLLOWUPS=5
NURTURE_QUIET_START_HOUR=21
NURTURE_QUIET_END_HOUR=8
NURTURE_QUIET_TZ=America/New_York

# ── Warmth Scoring ────────────────────────────────────────────────
WARMTH_COLD_THRESHOLD=30
WARMTH_WARM_THRESHOLD=60
WARMTH_HOT_THRESHOLD=80
WARMTH_DECAY_PER_DAY=2.0

# ── WebSocket ─────────────────────────────────────────────────────
WS_PATH=/ws
WS_HEARTBEAT_INTERVAL=30

# ── Frontend ──────────────────────────────────────────────────────
FRONTEND_URL=http://localhost:3000
